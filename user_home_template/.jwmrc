<?xml version="1.0"?>
<JWM>
  <StartupCommand>xterm -geometry 120x36 -fa Monospace -fs 12 -fg '#DDDDDD' -bg '#111111' -e bash -l</StartupCommand>

  <RootMenu onroot="12">
    <Program label="Terminal">xterm -geometry 120x36 -fa Monospace -fs 12 -fg '#DDDDDD' -bg '#111111' -e bash -l</Program>
    <Program label="Start VPN">xterm -geometry 120x35 -fa Monospace -fs 12 -fg '#DDDDDD' -bg '#111111' -e bash -lc 'cd "$HOME" || exit 1; ./vpn.sh; echo; echo "VPN exited. Press Enter to close."; read _'</Program>
    <Program label="Start internal RDP">xterm -geometry 120x35 -fa Monospace -fs 12 -fg '#DDDDDD' -bg '#111111' -e bash -lc 'cd "$HOME" || exit 1; ./rdp.sh; echo; echo "RDP exited. Press Enter to close."; read _'</Program>
    <Separator/>
    <Restart label="Restart JWM"/>
    <Exit label="Log Out" confirm="true"/>
  </RootMenu>

  <Tray x="0" y="-1" height="26">
    <TrayButton label="Menu">root:1</TrayButton>
    <TaskList maxwidth="256"/>
    <Clock format="%H:%M"/>
  </Tray>
</JWM>
