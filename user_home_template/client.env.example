# Copy to client.env and edit locally.
USERNAME="your.username"
PASSWORD="your-password-or-token"

VPN_SERVER="vpn.example.com"
# OpenConnect protocol, for example "gp".
VPN_PROTOCOL="gp"
# Optional: preselect a VPN gateway. If unset, vpn.exp accepts the default.
# VPN_GATEWAY="your-vpn-gateway"

# Primary target for the inner RDP connection.
WORKSPACE="workspace.example.com"
# Optional override when you need to bypass/force a specific address.
# WORKSPACE_IP="10.0.0.10"
REQUIRE_COUNTRY="US"

# Optional inner FreeRDP microphone redirection.
# RDP_MICROPHONE=0
# RDP_MIC_SOURCE=""
# RDP_MUTE_INPUTS=0
