# Copy to run-rdp-container.env and edit locally.
RDP_USER='rdpuser'
RDP_PASSWORD='replace-with-a-local-password'
APP_NAME='vpn-rdp'
CONTAINER_HOSTNAME='vpn-rdp'

# Access mode: direct exposes XRDP on 3389; ssh-tunnel exposes SSH on SSH_PORT and tunnels XRDP.
RDP_ACCESS_MODE='direct'
CONTAINER_FIREWALL='1'
SSH_PORT='2022'
# Optional override for ssh-tunnel mode. If unset, an Ed25519 key is created in the sudo-invoking user's ~/.ssh.
# SSH_KEY_FILE='~/.ssh/vpn-rdp-container_ed25519'
# Optional persistent container SSH server host keys directory. Ignored by git.
# SSH_HOST_KEYS_DIR='./ssh_host_keys'

# Required local network settings. Leave unset and the script fails loud.
# Find your physical LAN interface with: ip -br link
# Example: PARENT_IFACE='enp1s0'
PARENT_IFACE=''

# Use a stable locally administered MAC, then reserve it on your router.
# Example: CONTAINER_MAC='02:42:67:70:00:01'
CONTAINER_MAC=''

# Optional image tag.
# IMAGE_TAG='stable'
